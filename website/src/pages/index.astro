---
import Layout from "../layouts/layout.astro";
import DemoSection from "../components/demo-section";
import { HeroTitle } from "../components/hero-title";
import { ClipboardButton } from "@/components/clipboard-button";
import { CTAGlowWrapper } from "@/components/cta-glow-wrapper";
import Header from "@/components/header.astro";
import Background from "@/layouts/background.svelte";
import DimensionArc from "@/components/dimension-arc.astro";
import RulerTicks from "@/components/ruler-ticks.astro";
import DashedFrame from "@/components/dashed-frame.astro";
import { pseudoBorder } from "@/utils/pseudo-border";
import GitHubStar from "@/components/github-star.astro";
import { Footer } from "@/components/footer";
import DemoSkeleton from "@/components/demo-skeleton.astro";
import pkg from "../../../package.json";
const version = pkg.version;
---

<Layout title="Fractional Range">
  <Background client:only="svelte" />
  <Header />
  <main
    class="pt-12 small-device:pt-8 md:pt-16 flex items-center flex-col overflow-hidden mb-5"
  >
    <!-- Hero section wrapped in dashed frame -->
    <DashedFrame class="p-8 sm:p-12 w-full max-w-[600px] lg:max-w-[800px] mx-4">
      <div class="relative">
        <!-- Decorations sit around the reactive title -->
        <div class="relative mb-5">
          <DimensionArc />
          <HeroTitle client:load />
          <RulerTicks />
        </div>

        <p class="text-text-secondary text-base tracking-wide text-center mb-2">
          An opinionated React slider.
        </p>
        <p class="text-text-secondary/60 text-xs font-mono text-center mb-12">
          v{version}
        </p>
        <div
          class="flex gap-3 items-center flex-wrap justify-center sm:w-max-[unset] w-full px-5"
        >
          <CTAGlowWrapper href="/installation/" client:load />
          <div
            class:list={[
              "relative h-10 bg-[#111] text-sm text-text-secondary rounded-xl px-3 pr-1.5 font-mono flex gap-2 items-center sm:w-auto w-full",
              pseudoBorder({ radius: "xl" }),
            ]}
          >
            npm install fractionalrange
            <ClipboardButton
              title="Copy to clipboard"
              aria-label="copy to clipboard"
              className="sm:ml-0 ml-auto"
              client:load
            />
          </div>
        </div>
      </div>
    </DashedFrame>

    <!-- Interactive demo -->
    <DashedFrame
      class="mt-10 sm:mt-14 small-device:mt-8 w-full max-w-[600px] lg:max-w-[800px] mx-4 p-8 sm:p-12"
    >
      <div class="demo-container">
        <div class="demo-skeleton"><DemoSkeleton /></div>
        <DemoSection client:only="react" />
      </div>
    </DashedFrame>

    <!-- GitHub star -->
    <div class="mt-14 flex flex-col items-center gap-3">
      <p class="text-text-muted text-sm tracking-wide">
        If you liked this project, consider giving it a star
      </p>
      <GitHubStar />
    </div>
  </main>
  <Footer />
</Layout>
