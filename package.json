{
  "name": "fractionalrange",
  "version": "2.0.2",
  "description": "An opinionated slider component with ticks for React.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "style": "dist/styles.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts && cp src/styles.css dist/styles.css",
    "build:link": "bun run build && cp -r dist/ node_modules/.bun/fractionalrange@root/node_modules/fractionalrange/dist/",
    "dev:web": "bun run build:link && rm -rf website/node_modules/.vite && bun --filter website dev --host",
    "test": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/"
  },
  "keywords": [
    "react",
    "slider",
    "range",
    "fractional"
  ],
  "author": "Salvador Bacci",
  "license": "MIT",
  "homepage": "https://fractionalrange.bacci.dev",
  "repository": "https://github.com/baccci/fractionalrange",
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@testing-library/react": "^15.0.2",
    "@types/react": "^18.2.78",
    "@vitest/ui": "^1.5.0",
    "jsdom": "^24.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "motion": "^12.0.0"
  },
  "workspaces": [
    "website"
  ]
}
